# Slack webhook URL (use test channel for local dev)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Google Sheets
GOOGLE_SHEET_ID=your-sheet-id-from-url
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'

# Watchdog config (for manual runs via `node src/check.mjs`)
WATCHDOG_CONFIG='{"id":"test","property_url":"https://www.booking.com/hotel/property-to-watch.html","checkin_date":"2026-07-01","checkout_date":"2026-07-31","adults":2,"children":0,"min_nights":3}'

# Set to true to skip alerts and state writes
DRY_RUN=true
